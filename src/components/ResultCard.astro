---
const { label, context, screenshot } = Astro.props;
---

<div class="result-card">
  <div class="rc-label">
    <span class="rc-indicator">// {label}</span>
  </div>
  <div class="rc-context">{context}</div>
  <img src={screenshot} alt="Proof of work" loading="lazy" class="rc-screenshot seo-img" />
</div>

<style>
  .result-card {
    background: rgba(10, 20, 15, 0.6);
    border: 1px solid rgba(0, 232, 122, 0.2);
    border-left: 3px solid #00e87a;
    padding: 1.5rem;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .rc-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #00e87a;
    letter-spacing: 0.05em;
  }
  .rc-context {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .rc-screenshot {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid rgba(0, 232, 122, 0.1);
    transition: opacity 0.2s ease;
  }
  .rc-screenshot:hover {
    opacity: 0.9;
  }
</style>
