---
import PostLayout from '../../layouts/PostLayout.astro';
import { getHashnodePosts, getHashnodePost } from '../../lib/hashnode';

export async function getStaticPaths() {
  const host = import.meta.env.HASHNODE_HOST || 'henrybassey.hashnode.dev';
  const posts = await getHashnodePosts(host);
  
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const host = import.meta.env.HASHNODE_HOST || 'henrybassey.hashnode.dev';
const fullPost = await getHashnodePost(host, post.slug);
---

<PostLayout
  title={fullPost?.title || post.title}
  date={fullPost?.publishedAt || post.publishedAt}
  tag="Short"
  excerpt={fullPost?.brief || post.brief}
  backHref="/shorts"
  backLabel="All Shorts"
>
  {fullPost?.content?.html ? (
    <article set:html={fullPost.content.html} class="hashnode-content" />
  ) : (
    <p>Content could not be loaded.</p>
  )}
</PostLayout>
