<!-- ─── IMAGE OVERLAY MODAL ─── -->
<div id="image-modal" class="modal">
  <span class="modal-close">&times;</span>
  <img class="modal-content" id="modal-img" />
</div>

</Layout>

<script>
  // Global Parallax logic
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    // Hero image parallax
    const photoWrap = document.querySelector('.hero-photo-wrap');
    if (photoWrap) {
      (photoWrap as HTMLElement).style.transform = `translateY(${scrollY * 0.25}px)`;
    }

    // Data-parallax elements
    document.querySelectorAll('[data-parallax]').forEach(el => {
      const speed = parseFloat(el.getAttribute('data-parallax') || '0');
      // Only apply parallax if screen is reasonably wide (desktop) to save mobile performance
      if (window.innerWidth > 768) {
        // Calculate offset based on element position relative to viewport
        const rect = el.getBoundingClientRect();
        // Distance from center of viewport
        const offset = (window.innerHeight / 2 - (rect.top + rect.height / 2)) * speed;
        (el as HTMLElement).style.transform = `translateY(${-offset}px)`;
      } else {
        (el as HTMLElement).style.transform = 'none';
      }
    });
  });

  const phrases = [
    "grow developer trust.",
    "build advocacy systems.",
    "ship AI-powered tools.",
    "turn frameworks into pipeline.",
    "tell technical stories.",
    "connect product to market."
  ];
  let pi=0,ci=0,del=false;
  const el=document.getElementById('typed');

  if(el){
    function type(){
      const cur=phrases[pi];
      if(del){
        el.textContent=cur.slice(0,--ci);
        if(ci===0){
          del=false;
          pi=(pi+1)%phrases.length;
          setTimeout(type,400);
          return;
        }
        setTimeout(type,38);
      } else {
        el.textContent=cur.slice(0,++ci);
        if(ci===cur.length){
          del=true;
          setTimeout(type,2200);
          return;
        }
        setTimeout(type,62);
      }
    }

    setTimeout(type, 900);
  }

  // Image Modal Logic
  const modal = document.getElementById('image-modal');
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const closeBtn = document.querySelector('.modal-close');

  if (modal && modalImg && closeBtn) {
    document.querySelectorAll('.tc-screenshot, .rc-screenshot, .tb-img, .proof-img-card img, .seo-img-card img').forEach(img => {
      
      const triggerModal = function(e: Event) {
        e.preventDefault(); // Prevents both touch and click firing
        modal.style.display = 'flex';
        // force reflow for opacity transition
        void modal.offsetWidth;
        modal.classList.add('show');
        modalImg.src = (e.currentTarget as HTMLImageElement).src;
      };

      img.addEventListener('click', triggerModal);
      img.addEventListener('touchend', triggerModal);
    });

    const closeModal = () => {
      modal.classList.remove('show');
      setTimeout(() => { modal.style.display = 'none'; }, 300);
    };

    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('show')) closeModal();
    });
  }
</script>
