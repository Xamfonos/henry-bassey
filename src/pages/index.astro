---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import TestimonialCard from '../components/TestimonialCard.astro';
import ThreadBlock from '../components/ThreadBlock.astro';
import ResultCard from '../components/ResultCard.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const recentPosts = allPosts.slice(0, 2).map(p => ({
  slug: p.id,
  title: p.data.title,
  brief: p.data.excerpt,
  publishedAt: p.data.date,
  coverImage: p.data.coverImage ? { url: p.data.coverImage } : undefined,
}));
---

<Layout title="Henry Bassey — The Technical Marketer">

<!-- ─── HERO ─── -->
<div style="min-height:100vh; display:flex; flex-direction:column; justify-content:center; padding:6rem 2.5rem 4rem; max-width:960px; margin:0 auto; position:relative;">

  <div style="font-size:0.72rem; color:var(--green); letter-spacing:0.18em; text-transform:uppercase; margin-bottom:1.5rem; display:flex; align-items:center; gap:0.75rem; animation:fadeUp 0.6s ease 0.1s both;">
    <span style="width:28px; height:1px; background:var(--green); display:inline-block;"></span>
    Developer Marketer Content Strategist Technical Marketer
  </div>

  <h1 style="font-family:var(--font-sans); font-size:clamp(2.6rem,6.5vw,5.2rem); font-weight:800; line-height:1.06; color:#fff; letter-spacing:-0.025em; margin-bottom:0.3rem; animation:fadeUp 0.6s ease 0.2s both;">
    Some say I'm a<br/>
    <span style="color:var(--green)">badass technical</span><br/>
    <span style="color:var(--green)">marketer.</span>
  </h1>

  <p style="font-family:var(--font-sans); font-size:clamp(1rem,2.2vw,1.35rem); font-weight:600; color:var(--text-dim); margin-bottom:1.75rem; animation:fadeUp 0.6s ease 0.3s both;">
    What do you say?
  </p>

  <div style="display:flex; align-items:center; flex-wrap:wrap; gap:0.5rem; font-size:clamp(0.85rem,2vw,0.9rem); line-height:1.5; margin-bottom:2rem; color:var(--text-dim); animation:fadeUp 0.6s ease 0.35s both;">
    <span style="color:var(--green)">$</span>
    <span>I help devtools companies</span>
    <span style="display:inline-flex; align-items:center;">
      <span id="typed" style="color:var(--amber)"></span>
      <span style="display:inline-block; width:2px; height:1.2em; background:var(--amber); margin-left:2px; animation:blink 1s step-end infinite;"></span>
    </span>
  </div>



  <div style="display:flex; gap:1rem; flex-wrap:wrap; animation:fadeUp 0.6s ease 0.5s both;">
    <a href="#portfolio" class="btn btn-primary">↳ See my work</a>
    <a href="#contact" class="btn btn-ghost">Work with me</a>
  </div>

  <div class="hero-photo-wrap">
    <img src="/assets/testimonials%20and%20proof%20of%20work/hero%20image.PNG" alt="Henry Bassey" />
  </div>

  <div class="marquee-wrap" style="position:absolute; bottom:2.5rem; left:0; right:0; animation:fadeUp 0.6s ease 0.7s both;">
    <div class="marquee-track">
      {['Developer Marketing','Content Strategy','Technical Writing','SEO & Growth','GTM Strategy','Developer Relations','Community Building','API & DevTools','Product Marketing',
        'Developer Marketing','Content Strategy','Technical Writing','SEO & Growth','GTM Strategy','Developer Relations','Community Building','API & DevTools','Product Marketing'
      ].map(item => (
        <span class="marquee-item">{item}<span class="dot"> ·</span></span>
      ))}
    </div>
  </div>
</div>

<!-- ─── RECENT POSTS ─── -->
{recentPosts.length > 0 && (
  <section id="recent-posts" class="section-wrap" style="padding-top: 2rem;">
    <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> Latest thoughts <span class="br">/&gt;</span></div>
    
    <div class="recent-posts-grid">
      {/* Primary Latest Post */}
      {recentPosts[0] && (
        <a href={`/blog/${recentPosts[0].slug}`} class="featured-post-card">
          {recentPosts[0].coverImage && (
            <div class="fp-image-wrap">
              <img src={recentPosts[0].coverImage.url} alt={recentPosts[0].title} />
            </div>
          )}
          <div class="fp-content">
            <div class="fp-meta">
              <span class="fp-date">{new Date(recentPosts[0].publishedAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
              <span class="fp-badge">NEW</span>
            </div>
            <h3 class="fp-title">{recentPosts[0].title}</h3>
            <p class="fp-excerpt">{recentPosts[0].brief}</p>
            <div class="fp-read">Read Article →</div>
          </div>
        </a>
      )}

      {/* Stacked Post */}
      {recentPosts[1] && (
        <a href={`/blog/${recentPosts[1].slug}`} class="stacked-post-card">
          <div class="sp-content">
            <div class="sp-meta">
              <span class="sp-date">{new Date(recentPosts[1].publishedAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
            </div>
            <h4 class="sp-title">{recentPosts[1].title}</h4>
            <p class="sp-excerpt">{recentPosts[1].brief}</p>
            <div class="sp-read">Read Article →</div>
          </div>
        </a>
      )}
    </div>
  </section>
)}

<!-- ─── ABOUT ─── -->
<section id="about" class="section-wrap">

  <div class="about-grid" data-parallax="0.1">
    <div>
      <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> Hi, I'm Henry Bassey <span class="br">/&gt;</span></div>
      <div style="font-size:0.85rem; color:var(--text-dim); font-family:var(--font-mono); margin-bottom:1.5rem;">A Developer Marketer, Content & SEO Specialist, and a Cloud Engineering Student.</div>
      <p style="font-size:0.88rem; line-height:2.1; color:var(--text); margin-bottom:1.1rem;">I started out in tech. Built things. Broke things. Learned a lot. Then I realized I was also good with words. And obsessed with storytelling.</p>
      <p style="font-size:0.88rem; line-height:2.1; color:var(--text); margin-bottom:1.1rem;">So I wandered into marketing. Got curious. Got serious. Picked up an MBA (full scholarship, thank you) from a business school in Washington.</p>
      <p style="font-size:0.88rem; line-height:2.1; color:var(--text); margin-bottom:1.1rem;">Later, I found technical marketing. Finally, a place where tech, creativity, and strategy could live in the same room.</p>
      <p style="font-size:0.88rem; line-height:2.1; color:var(--text); margin-bottom:1.1rem;">These days, I lead content at a SaaS agency, helping teams talk to developers like humans. People often say I bring creativity into a space that usually feels rigid. I take that personally.</p>
      <p style="font-size:0.88rem; line-height:2.1; color:var(--text); margin-bottom:2rem;">This is where I share my work, think out loud, and keep figuring it all out.</p>

      <div class="section-tag" style="white-space: normal; font-size: clamp(1rem, 2vw, 1.25rem); margin-bottom: 1.25rem;"><span class="br">&lt;</span> Some brands I've worked with. Not a flex. Just context. <span class="br">/&gt;</span></div>
      <div class="brands-grid">
        {[
          ['Hackmamba','https://hackmamba.io'],['Actian','https://www.actian.com/'],['Bitcloud','https://bit.dev'],['Aikido','https://www.aikido.dev/'],['MetalBear','https://metalbear.co'],
          ['Neon','https://neon.tech'],['Code First Girls','https://codefirstgirls.com'],
          ['Roadmap.sh','https://roadmap.sh'],['Mintlify','https://mintlify.com'],
          ['Mia-Platform','https://mia-platform.eu'],['Cloudinary','https://cloudinary.com'],
          ['Flutterwave','https://flutterwave.com'],['CodeRabbit','https://coderabbit.ai'],
          ['Novu','https://novu.co'],['Sourcegraph','https://sourcegraph.com'],
          ['Appwrite','https://appwrite.io'],['Replit','https://replit.com'],
          ['Hygraph','https://hygraph.com'],['Localazy','https://localazy.com'],
        ].map(([name, url]) => (
          <a href={url} target="_blank" rel="noopener" class="brand-chip">{name}</a>
        ))}
      </div>
    </div>

    <div>
      <div class="terminal-card">
        <div class="tc-head">
          <span class="wdot dr"></span><span class="wdot dy"></span><span class="wdot dg"></span>
          <span class="tc-filename">henry_bassey.json</span>
        </div>
        <div class="tc-body">
          <div class="tl"><span class="tp">$</span><span class="tc2">cat henry_bassey.json</span></div>
          <div class="tb"></div>
          <div class="tl"><span class="tg">{'{'}</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"name"</span><span class="tc2">:&nbsp;</span><span class="tv">"Henry Bassey"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"role"</span><span class="tc2">:&nbsp;</span><span class="tv">"Technical Marketer & Builder"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"handle"</span><span class="tc2">:&nbsp;</span><span class="tv">"@xamfonos_"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"education"</span><span class="tc2">: [</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"MBA (Full Scholarship)"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"Cloud Engineering (in progress)"</span></div>
          <div class="tl"><span class="ind"></span><span class="tc2">],</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"focus"</span><span class="tc2">: [</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"Developer Marketing Strategy"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"AI Software Development"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"Marketing Frameworks & Systems"</span><span class="tc2">,</span></div>
          <div class="tl"><span class="ind2"></span><span class="tv">"Performance Marketing"</span></div>
          <div class="tl"><span class="ind"></span><span class="tc2">],</span></div>
          <div class="tl"><span class="ind"></span><span class="tk">"available"</span><span class="tc2">:&nbsp;</span><span style="color:var(--green)">true</span></div>
          <div class="tl"><span class="tg">{'}'}</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── SKILLS ─── -->
<section id="skills" class="section-wrap">
  <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> My Skills & Expertise. <span class="br">/&gt;</span></div>
  <div style="font-size:0.85rem; color:var(--text-dim); font-family:var(--font-mono); margin-bottom:2.5rem;">The intersections where I bring the most value.</div>

  <div class="skills-grid">
    <div class="skill-group">
      <div class="sg-title">Developer Marketing & Strategy</div>
      <div class="skill-tags">
        {['GTM strategy', 'Product marketing', 'Developer audience messaging', 'Launch strategy', 'Competitive positioning', 'PLG', 'Developer relations advisory'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">Brand Building & Positioning</div>
      <div class="skill-tags">
        {['Zero-to-one brand building', 'Brand voice development', 'Messaging frameworks', 'Product positioning'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">AI & Software Development</div>
      <div class="skill-tags">
        {['AI-powered websites', 'Automations & workflows', 'App development', 'Marketing tools & systems', 'AI-assisted content operations'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">SEO & Performance Marketing</div>
      <div class="skill-tags">
        {['Keyword research', 'Topic cluster mapping', 'Inbound lead generation', 'PPC', 'Paid media', 'On/off-page optimization', 'E-commerce SEO', 'Content-led growth'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">Content & Technical Writing</div>
      <div class="skill-tags">
        {['Technical copywriting', 'Performance copy', 'Ghostwriting', 'Thought leadership', 'Editorial systems', 'Briefs'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">Social Media & Community</div>
      <div class="skill-tags">
        {['Social media strategy & management', 'Community building', 'Developer relations', 'Mentorship', 'Technical instruction'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">Content Operations</div>
      <div class="skill-tags">
        {['Content strategy', 'Writer management', 'Editorial standards', 'SME interviews', 'Content audits', 'Agency-side delivery', 'Content pillar architecture'].map(s => <span class="skill-tag">{s}</span>)}
      </div>
    </div>
  </div>
</section>

<!-- ─── SERVICES ─── -->
<section id="services" class="section-wrap">
  <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> What's going on here? <span class="br">/&gt;</span></div>
  <div style="font-size:0.85rem; color:var(--text-dim); font-family:var(--font-mono); margin-bottom:2.5rem;">Honestly? A little bit of everything.</div>

  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:2.5rem;" data-parallax="0.05">
    <div class="skill-group">
      <div class="sg-title">If you're building something for developers, I can help you</div>
      <div style="display:grid; gap:0.1rem; margin-top:0.5rem;">
        <div class="svc-item">Build a developer marketing strategy that actually maps to how developers discover, evaluate, and adopt tools.</div>
        <div class="svc-item">Launch products to the right audience with messaging, timing, and channels that don't embarrass the engineering team.</div>
        <div class="svc-item">Write performance copy for ads, homepages, docs, and product pages that converts without reading like a pitch deck.</div>
        <div class="svc-item">Build SEO/GEO/AEO pages that earn rankings and actually get read.</div>
        <div class="svc-item">Design and implement AI-powered marketing systems, workflows, and tools that scale what your team can do.</div>
        <div class="svc-item">Connect the dots between product, content, brand, and GTM so none of them are pulling in different directions.</div>
      </div>
    </div>
    <div class="skill-group">
      <div class="sg-title">If you're a marketer, writer, or strategist trying to level up</div>
      <div style="display:grid; gap:0.1rem; margin-top:0.5rem;">
        <div class="svc-item">I share behind-the-scenes breakdowns of real campaigns, strategies, and frameworks like the good, the messy, and the fixed.</div>
        <div class="svc-item">I write about positioning, narrative, and the difference between publishing and actually saying something.</div>
        <div class="svc-item">I break down how to think about developer audiences without dumbing things down or going full Clippy.</div>
        <div class="svc-item">I share the frameworks I've built from real client work and not theory, not templates from a listicle.</div>
        <div class="svc-item">And I talk a lot about the hard part of operating at a strategic level when everyone just wants more content.</div>
      </div>
    </div>
  </div>
</section>

<!-- ─── FRAMEWORKS ─── -->
<section id="frameworks" class="section-wrap">
  <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> These are mine. <span class="br">/&gt;</span></div>
  <div style="font-size:0.85rem; color:var(--text-dim); font-family:var(--font-mono); margin-bottom:2.5rem; line-height:1.7;">Frameworks I built from scratch. Named, documented, and used in real client work.</div>

  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px,1fr)); gap:1.1rem;" data-parallax="0.08">
    {[
      { url: 'https://hackmamba.io/developer-marketing/the-halo-signal-and-share-framework/', name: 'Halo Signal Strategy', desc: 'How to build brand trust and demonstrate value before you have a formal case study.', applied: 'Replit, Hackmamba' },
      { url: 'https://hackmamba.io/developer-marketing/the-halo-signal-and-share-framework/', name: 'SHARE Framework', desc: 'How to craft respectful, strategic client spotlights that protect relationships while proving impact.', applied: 'Hackmamba' },
      { url: '#', name: 'Developer Advocacy Architecture (DAA)', desc: 'How to build a systematic, scalable developer advocacy program from the ground up.', applied: 'Hackmamba' },
      { url: 'https://github.com/Xamfonos/technical-writing-best-practices', name: 'Technical Editing Claude Skills', desc: 'How to review and restructure technical content so each section earns the next.', applied: 'Hackmamba, client content reviews' },
      { url: 'https://hackmamba.io/technical-writing-glossary/', name: 'Hackmamba Technical Writing Glossary', desc: 'How to structure, write, and edit technical content so it\'s clear, confident, and genuinely useful for developers.', applied: 'Hackmamba, client content reviews' }
    ].map(f => (
      <a href={f.url} target="_blank" rel="noopener" class="f-card">
        <div class="f-name">{f.name}</div>
        <div class="f-desc"><strong style="color:var(--text); font-weight:600;">Problem it solves:</strong> {f.desc}</div>
        <div class="f-applied">Applied at: {f.applied}</div>
      </a>
    ))}
  </div>
</section>

<!-- ─── PORTFOLIO ─── -->
<section id="portfolio" class="section-wrap">
  <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> Most of my work falls into strategy, messaging, and content operations. <span class="br">/&gt;</span></div>
  <div style="font-size:0.85rem; color:var(--text-dim); font-family:var(--font-mono); margin-bottom:2.5rem;">But at the end of the day, it's all about helping you figure out how to win your customer’s heart. Here’s how that looks like in practice.</div>

  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px,1fr)); gap:1.1rem;" data-parallax="0.04">
    {[
      { url:'https://www.hackmamba.io', type:'Developer Marketing Agency SaaS', name:'Hackmamba', desc:"Joined when it was a side hustle with no roadmap, just a belief. Started as the fullstack developer marketer doing everything from landing pages, ads, lead funnels, brand voice and messaging. As the company grew and client quality became an issue, I moved into the Head of Marketing role to raise the editorial bar and implement the standards that now define how the agency operates.", tags:['Brand Leadership','Head of Marketing','Content Strategy','SEO','Dev Marketing','DAA'] },
      { url:'https://www.actian.com/', type:'Data Management Platform Vector AI Database', name:'Actian', desc:"Onboarded as Head of Content to lead the launch of their new VectorAI database product. Built the product page copy from scratch, created SEO, technical content, and video strategy for both launch and relaunch. Three months in, the early results were significant enough that they extended the engagement from 6 months to a full year.", tags:['Head of Content','Product Launch','VectorAI','SEO','Video Strategy','Technical Copy'] },
      { url:'#', type:'AI Software Development', name:'Bitcloud', desc:"I managed their entire content strategy and helped them pivot their messaging multiple times as the AI software development market evolved. We became their most trusted GTM arm.", tags:['Content Strategy','Messaging Pivot'] },
      { url:'https://thenewstack.io', type:'Tech Media Developer Insights', name:'The New Stack', desc:"First media brand I collaborated with. Sharpened raw ideas into editorially rigorous articles. Became a contributor writing on developer marketing, GenAI, and data science for names like Boomi, BMC, Towards Data Science, and Plotly.", tags:['Thought Leadership','Technical Writing','SEO'] },
      { url:'https://mia-platform.eu', type:'DevOps Platform Backend Infrastructure', name:'Mia-Platform', desc:"One of our earliest long-term partners. Executed their content strategy, which involved articles and whitepapers for a deeply technical audience. Their sustained trust became one of our strongest proof points.", tags:['Content Strategy','Whitepapers','Technical Messaging'] },
      { url:'https://cloudinary.com', type:'Digital Asset Management Media APIs', name:'Cloudinary', desc:"Translated their goals into structured content pillars, mapped SEO-driven topic clusters, and built briefs that matched technical expectations with search demand. Earned their trust and repeat projects.", tags:['SEO Strategy','Content Pillars','Briefs'] },
      { url:'https://kitops.org', type:'AI/ML Platforms DevTools', name:'Jozu / KitOps', desc:"Turned complex product ideas into focused, high-utility content. Shaped editorial direction, fine-tuned titles for discoverability, and built briefs that gave technical writers a strong foundation to work from.", tags:['AI/ML Content','Editorial Strategy','DevTools'] },
      { url:'https://flutterwave.com', type:'Fintech API Developer Marketing', name:'Flutterwave', desc:"First unicorn we worked with, and they had zero developer marketing content strategy. I stepped in to shape it from scratch, defined messaging for their developer audience, and launched content that supported product education and discovery.", tags:['Zero-to-One Strategy','Fintech','Dev Marketing'] },
      { url:'https://www.coderabbit.ai', type:'AI Code Review DevTools SaaS', name:'CodeRabbit', desc:"Helped turn early topic drafts into structured briefs, refined themes for SEO and audience fit, and guided technical writers through execution, giving their product a clear, consistent voice in a fast-growing space.", tags:['AI DevTools','Content Briefs','SEO'] },
      { url:'https://roadmap.sh', type:'Developer Education SEO Strategy', name:'Roadmap.sh', desc:"Worked with their deeply experienced SEO team. Shaped raw keyword data into structured briefs and produced content that answered real developer questions. Their rigorous process made me a sharper operator.", tags:['SEO Strategy','Dev Education','Content Briefs'] },
      { url:'https://mintlify.com', type:'Documentation Platform Developer Tools', name:'Mintlify', desc:"Partnered with Tiffany Chen to shape abstract content goals into execution-ready assets. Co-developed titles, briefs, and outlines. Interviewed SMEs to deepen material and sharpen its perspective.", tags:['Docs Strategy','SME Interviews','Technical Content'] },
      { url:'https://neon.tech', type:'Serverless Postgres Database Tools', name:'Neon', desc:"Translated a sharp technical vision into structured strategy, from keyword research to briefs to final execution. Built content to engage developers, match search intent, and reflect Neon's next-gen database positioning.", tags:['Database Content','Dev Engagement','SEO'] },
      { url:'https://novu.co', type:'Notification Infrastructure Open Source', name:'Novu', desc:"Helped Novu stay top-of-mind for developers solving notification problems. From onboarding guides to integration tutorials, everything was structured to reflect their open-source roots and real developer workflows.", tags:['Open Source','Dev Tutorials','Content Ops'] },
      { url:'https://sourcegraph.com', type:'Code Search Developer Tools', name:'Sourcegraph', desc:"Created content that reflected the depth of their platform without losing developers in complexity. Refined positioning, shaped strategy into clear briefs, and guided content from first draft to final edits.", tags:['Code Tools','Technical Accuracy','Dev-First Content'] },
      { url:'https://hygraph.com', type:'Headless CMS Developer Marketing', name:'Hygraph', desc:"Helped implement their developer marketing strategy, structured SEO efforts around technical topics, and produced content that competed at the top of the funnel, even on highly competitive React keywords.", tags:['Headless CMS','Dev Marketing','SEO'] },
      { url:'https://appwrite.io', type:'Open Source Backend Developer Tools', name:'Appwrite', desc:"A rare zero-to-one project. Built their content strategy from scratch, structuring it around product goals and a developer-first audience. We helped a dev-first brand find its rhythm and its voice.", tags:['Zero-to-One','Open Source','Brand Voice'] },
      { url:'https://replit.com', type:'Cloud IDE Developer Platform', name:'Replit', desc:"Supported with docs and video content. Writing the collaboration announcement sparked the invention of the Halo Signal Strategy and SHARE Framework, methods for showing proof of value without a formal case study.", tags:['DevRel','Halo Signal','SHARE Framework'] },
      { url:'https://codefirstgirls.com', type:'Edutech Community Mentorship', name:'Code First Girls', desc:"Joined as the only male instructor in my cohort, teaching React and JavaScript to an all-women group of aspiring developers. Built confidence, shared real-world experience, and helped more women break into tech.", tags:['React','JavaScript','Mentorship'] },
      { url:'#', type:'Industrial Electricals E-commerce SEO', name:'Detopsy Engineering', desc:"First and only marketing executive. Built the e-commerce website, optimized product listings for top-ranking search performance, and secured official Schneider Electric retailer approval. Also ranked for ABB, pulling organic traffic from across regions.", tags:['E-commerce SEO','Brand Partnerships','Web Development'] },
    ].map(p => (
      <a href={p.url} target="_blank" rel="noopener" class="p-card">
        <div class="p-type">{p.type}</div>
        <div class="p-name">{p.name}</div>
        <div class="p-desc">{p.desc}</div>
        <div class="p-tags">
          {p.tags.map(t => <span class="p-tag">{t}</span>)}
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ─── FEATURED WRITING ─── -->
<section id="articles" class="section-wrap">
  <div class="section-tag" style="white-space: normal; margin-bottom: 0.5rem;"><span class="br">&lt;</span> The point of all this? <span class="br">/&gt;</span></div>
