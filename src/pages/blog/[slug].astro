---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  date={new Date(post.data.date)}
  excerpt={post.data.excerpt}
  category={post.data.category}
  backHref="/blog"
  backLabel="Back to Blog"
  ogImage={post.data.coverImage}
>
  {post.data.coverImage && (
    <div style="margin-bottom: 2.5rem; border-radius: 8px; overflow: hidden; border: 1px solid var(--border);">
      <img src={post.data.coverImage} alt={post.data.title} style="width:100%; display:block; max-height:420px; object-fit:cover;" />
    </div>
  )}

  {post.data.tags.length > 0 && (
    <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem;">
      {post.data.tags.map(tag => (
        <span style="font-size:0.68rem; padding:0.2rem 0.55rem; border:1px solid var(--border); border-radius:3px; color:var(--text-dim); background:var(--bg3);">{tag}</span>
      ))}
    </div>
  )}

  <Content />
</PostLayout>
