---
import { getHashnodePosts, getHashnodePost } from '../../lib/hashnode';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const host = import.meta.env.HASHNODE_HOST || 'henrybassey.hashnode.dev';
  const posts = await getHashnodePosts(host);
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const host = import.meta.env.HASHNODE_HOST || 'henrybassey.hashnode.dev';
const post = await getHashnodePost(host, slug!);

if (!post) {
  return Astro.redirect('/blog');
}
---

<PostLayout
  title={post.title}
  date={new Date(post.publishedAt)}
  excerpt={post.brief}
  backHref="/blog"
  backLabel="Back to Blog"
  ogImage={post.coverImage?.url}
>
  {post.coverImage && (
    <div style="margin-bottom: 2.5rem; border-radius: 8px; overflow: hidden; border: 1px solid var(--border);">
      <img src={post.coverImage.url} alt={post.title} style="width:100%; display:block; max-height:420px; object-fit:cover;" />
    </div>
  )}

  {post.tags && post.tags.length > 0 && (
    <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem;">
      {post.tags.map(tag => (
        <span style="font-size:0.68rem; padding:0.2rem 0.55rem; border:1px solid var(--border); border-radius:3px; color:var(--text-dim); background:var(--bg3);">{tag.name}</span>
      ))}
    </div>
  )}

  <div set:html={post.content.html} />
</PostLayout>
