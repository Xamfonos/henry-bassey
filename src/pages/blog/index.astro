---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog — Henry Bassey" description="Writing on developer marketing, content strategy, and building in public.">

  <div style="max-width:960px; margin:0 auto; padding:8rem 2.5rem 5rem;">

    <div style="margin-bottom:3rem;">
      <div style="font-size:0.72rem; color:var(--green); letter-spacing:0.18em; text-transform:uppercase; margin-bottom:1rem; display:flex; align-items:center; gap:0.75rem;">
        <span style="width:28px; height:1px; background:var(--green); display:inline-block;"></span>
        Writing
      </div>
      <h1 style="font-family:var(--font-sans); font-size:clamp(2.2rem,5vw,3.5rem); font-weight:800; color:#fff; line-height:1.1; letter-spacing:-0.025em; margin-bottom:0.75rem;">
        Thoughts, breakdowns,<br/>and things I figured out.
      </h1>
      <p style="font-size:0.9rem; color:var(--text-dim); line-height:1.75; max-width:600px;">
        Developer marketing, content strategy, technical writing, and the messy middle of operating at a strategic level. All of it.
      </p>
    </div>

    {posts.length === 0 && (
      <div style="text-align:center; padding:4rem 0; color:var(--text-dim);">
        <div style="font-size:0.85rem;">No posts yet. Check back soon.</div>
      </div>
    )}

    <div class="blog-list">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}`} class="blog-list-item">
          <div class="bli-left">
            {post.data.coverImage && (
              <div class="bli-cover">
                <img src={post.data.coverImage} alt={post.data.title} />
              </div>
            )}
          </div>
          <div class="bli-body">
            <div class="bli-meta">
              <span class="bli-date">{new Date(post.data.date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
              {i === 0 && <span class="bli-new">LATEST</span>}
              {post.data.tags.slice(0,2).map(tag => (
                <span class="bli-tag">{tag}</span>
              ))}
            </div>
            <h2 class="bli-title">{post.data.title}</h2>
            <p class="bli-excerpt">{post.data.excerpt}</p>
            <div class="bli-read">Read article →</div>
          </div>
        </a>
      ))}
    </div>

  </div>

</Layout>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .blog-list-item {
    display: flex;
    gap: 1.5rem;
    background: var(--bg2);
    padding: 1.5rem;
    text-decoration: none;
    transition: background 0.15s;
    align-items: flex-start;
  }

  .blog-list-item:hover {
    background: var(--bg3);
  }

  .bli-left { flex-shrink: 0; }

  .bli-cover {
    width: 96px;
    height: 64px;
    border-radius: 5px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .bli-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bli-body { flex: 1; min-width: 0; }

  .bli-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .bli-date {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .bli-new {
    font-size: 0.58rem;
    padding: 0.12rem 0.4rem;
    background: var(--green);
    color: var(--bg);
    border-radius: 3px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .bli-tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-dim);
    background: var(--bg3);
  }

  .bli-title {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.35;
    margin-bottom: 0.45rem;
    transition: color 0.15s;
  }

  .blog-list-item:hover .bli-title { color: var(--green); }

  .bli-excerpt {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bli-read {
    font-size: 0.75rem;
    color: var(--green);
    font-weight: 600;
  }

  @media (max-width: 580px) {
    .blog-list-item { flex-direction: column; }
    .bli-cover { width: 100%; height: 140px; }
  }
</style>
