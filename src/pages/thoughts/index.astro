---
import Layout from '../../layouts/Layout.astro';
import { getHashnodePosts } from '../../lib/hashnode';

// User's Hashnode public domain URL
const host = import.meta.env.HASHNODE_HOST || 'henrybassey.hashnode.dev';
const posts = await getHashnodePosts(host);
---

<Layout title="Thoughts — Henry Bassey" description="Thinking out loud on developer marketing, technical writing, and content strategy.">
  <div class="section-wrap" style="padding-top:8rem;">

    {posts.length > 0 ? (
      <div class="thoughts-list">
        {posts.map(post => (
          <a href={`/thoughts/${post.slug}`} class="thought-item">
            <div>
              <div class="thought-cat">{new Date(post.publishedAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</div>
              <div class="thought-title">{post.title}</div>
              {post.brief && (
                <div class="thought-excerpt">{post.brief}</div>
              )}
              {post.tags && post.tags.length > 0 && (
                <div class="blog-tags">
                  {post.tags.map(tag => (
                    <span class="blog-tag-small">{tag.name}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : <div style="padding:2rem; border:1px solid var(--border); border-radius:8px; font-size:0.85rem; color:var(--text-dim); text-align:center; font-style:italic;">Nothing here yet. Still connecting the dots.</div>}

  </div>
</Layout>

  </div>
</Layout>
