            "Technical Reviews",
            "Case Studies",
            "Content Strategy",
            "SEO & GEO",
            "Uncategorized"
          ],
          "default": "Uncategorized"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date",
        "excerpt"
      ],
      "additionalProperties": false
    }
